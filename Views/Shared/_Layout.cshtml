<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eInsurance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EInsurance.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>

    @* ── Navbar ── *@
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold"
                   asp-controller="Home" asp-action="Index">
                 EInsurance
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">

                    @* Show when NOT logged in *@
                    @if (Context.Session.GetString("Role") == null)
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="AuthView"
                               asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="AuthView"
                               asp-action="Register">Register</a>
                        </li>
                    }

                    @* Show when Admin *@
                    @if (Context.Session.GetString("Role") == "Admin")
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Admin"
                               asp-action="Dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Policy"
                               asp-action="CustomerPolicies">📋 Customer Policies</a>
                        </li>
                    }

                    @* Show when Customer *@
                    @if (Context.Session.GetString("Role") == "Customer")
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Policy"
                               asp-action="MyPolicies">My Policies</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Payment"
                               asp-action="MyPayments">My Payments</a>
                        </li>
                    }

                    @* Show when Agent *@
                    @if (Context.Session.GetString("Role") == "Agent")
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Agent"
                               asp-action="Dashboard">Dashboard</a>
                        </li>
                    }

                    @* Show when Employee *@
                    @if (Context.Session.GetString("Role") == "Employee")
                    {
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Employee"
                               asp-action="Dashboard">Dashboard</a>
                        </li>
                    }

                    @* Show logged in user name + logout *@
                    @if (Context.Session.GetString("Role") != null)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-warning">
                                👤 @Context.Session.GetString("FullName")
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger"
                               asp-controller="AuthView"
                               asp-action="Logout">Logout</a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>

    @* ── Page Content ── *@
    <div class="container mt-4">
        @RenderBody()
    </div>

    @* ── Footer ── *@
    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - eInsurance
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>

