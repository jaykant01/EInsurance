@model List<EInsurance.Models.DTOs.CustomerPolicyDto>

@{
    ViewData["Title"] = "My Policies";
}

@* Success/Error Messages *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
         @TempData["Success"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
         @TempData["Error"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 My Policies</h2>
    <span class="badge bg-primary fs-6">
        Total: @Model.Count policies
    </span>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center">
        <h5>You have no policies yet.</h5>
        <p>Contact your agent to purchase a policy.</p>
        <a asp-controller="PolicyPurchase"
               asp-action="AvailablePlans"
               class="btn btn-primary mt-2">
             Browse Plans
        </a>
    </div>
}
else
{
    @foreach (var policy in Model)
    {
        <div class="card shadow mb-4">

            @* Policy Header *@
            <div class="card-header bg-primary text-white
                d-flex justify-content-between
                align-items-center">
                <h5 class="mb-0">
                    📄 Policy #@policy.PolicyID —
                    @policy.SchemeName
                </h5>
                <span class="badge bg-light text-primary">
                    @policy.PlanName
                </span>
            </div>

            <div class="card-body">
                <div class="row">

                    @* ── Policy Details ── *@
                    <div class="col-md-6">
                        <h6 class="text-muted">Policy Information</h6>
                        <table class="table table-sm">
                            <tr>
                                <td><strong>Details</strong></td>
                                <td>@policy.PolicyDetails</td>
                            </tr>
                            <tr>
                                <td><strong>Premium</strong></td>
                                <td class="text-success fw-bold">
                                    ₹@policy.Premium.ToString("N2")
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Date Issued</strong></td>
                                <td>@policy.DateIssued.ToString("dd MMM yyyy")</td>
                            </tr>
                            <tr>
                                <td><strong>Maturity Period</strong></td>
                                <td>@policy.MaturityPeriod years</td>
                            </tr>
                            <tr>
                                <td><strong>Lapse Date</strong></td>
                                <td class="text-danger">
                                    @policy.PolicyLapseDate.ToString("dd MMM yyyy")
                                </td>
                            </tr>
                        </table>

                        @* Pay Button *@
                        <div class="mt-2">
                            <a asp-controller="Payment"
                                   asp-action="Pay"
                                   asp-route-policyId="@policy.PolicyID"
                                   class="btn btn-success w-100">
                                💳 Pay Premium
                                ₹@policy.Premium.ToString("N2")
                            </a>
                        </div>

                        @* View Receipts — only if payments exist *@
                        @if (policy.Payments.Any())
                        {
                            <div class="mt-2">
                                <a asp-controller="Receipt"
                                       asp-action="MyPayments"
                                       class="btn btn-outline-primary w-100">
                                     View Receipts
                                </a>
                            </div>
                        }
                    </div>

                    @* ── Payment History ── *@
                    <div class="col-md-6">
                        <h6 class="text-muted">
                            Payment History
                            <span class="badge bg-success ms-2">
                                @policy.Payments.Count payments
                            </span>
                        </h6>

                        @if (!policy.Payments.Any())
                        {
                            <div class="alert alert-warning">
                                <strong>No payments made yet.</strong>
                                <br />
                                <small>
                                    Click "Pay Premium" to make
                                    your first payment.
                                </small>
                            </div>
                        }
                        else
                        {
                            <table class="table table-sm table-striped">
                                <thead class="table-success">
                                    <tr>
                                        <th>#</th>
                                        <th>Amount</th>
                                        <th>Date</th>
                                        <th>Receipt</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payment in policy.Payments)
                                    {
                                        <tr>
                                            <td>@payment.PaymentID</td>
                                            <td class="text-success">
                                                ₹@payment.Amount.ToString("N2")
                                            </td>
                                            <td>
                                                @payment.PaymentDate.ToString("dd MMM yyyy")
                                            </td>
                                            <td>
                                                <a asp-controller="Receipt"
                                                       asp-action="ViewReceipt"
                                                       asp-route-id="@payment.PaymentID"
                                                       class="btn btn-sm btn-outline-success">
                                                    🧾
                                                </a>
                                                <a asp-controller="Receipt"
                                                       asp-action="Download"
                                                       asp-route-id="@payment.PaymentID"
                                                       class="btn btn-sm btn-success">
                                                    ⬇️
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-success">
                                    <tr>
                                        <td colspan="2">
                                            <strong>Total Paid</strong>
                                        </td>
                                        <td colspan="2"
                                            class="text-success fw-bold">
                                            ₹@(policy.Payments.Sum(p => p.Amount).ToString("N2"))
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        }
                    </div>

                </div>
            </div>

            @* Card Footer *@
            <div class="card-footer bg-light d-flex
                justify-content-between align-items-center">
                <small class="text-muted">
                    Policy ID: #@policy.PolicyID |
                    Scheme: @policy.SchemeName
                </small>
                <small class="text-muted">
                    @policy.Payments.Count payment(s) made |
                    Total: ₹@(policy.Payments.Sum(p => p.Amount).ToString("N2"))
                </small>
            </div>

        </div>
    }
}