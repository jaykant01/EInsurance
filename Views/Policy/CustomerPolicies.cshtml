@model List<EInsurance.Models.DTOs.CustomerSearchDto>

@{
    ViewData["Title"] = "Customer Policies";
}

<h2 class="mb-4">🔍 Customer Policies</h2>

@* Search Bar *@
<div class="card shadow mb-4">
    <div class="card-body">
        <form asp-controller="Policy"
              asp-action="CustomerPolicies"
              method="get"
              class="row g-2">
            <div class="col-md-9">
                <input type="text"
                       name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder="🔍 Search by customer name or email..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    Search
                </button>
            </div>
            <div class="col-md-1">
                <a asp-controller="Policy"
                   asp-action="CustomerPolicies"
                   class="btn btn-secondary w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

@* Results Table *@
<div class="card shadow">
    <div class="card-body">
        <table class="table table-hover table-striped">
            <thead class="table-primary">
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Agent</th>
                    <th>Total Policies</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                            {
                                <span>No customers found for "@ViewBag.Search"</span>
                            }
                            else
                            {
                                <span>No customers in the system yet.</span>
                            }
                        </td>
                    </tr>
                }
                @foreach (var customer in Model)
                {
                    <tr>
                        <td>@customer.CustomerID</td>
                        <td>@customer.FullName</td>
                        <td>@customer.Email</td>
                        <td>@customer.Phone</td>
                        <td>@customer.AgentName</td>
                        <td>
                            <span class="badge bg-primary">
                                @customer.TotalPolicies
                            </span>
                        </td>
                        <td>
                            <a asp-controller="Policy"
                                   asp-action="CustomerPolicyDetails"
                                   asp-route-id="@customer.CustomerID"
                                   class="btn btn-sm btn-primary">
                                📋 View Policies
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Admin"
       asp-action="Dashboard"
       class="btn btn-secondary">← Back to Dashboard</a>
</div>