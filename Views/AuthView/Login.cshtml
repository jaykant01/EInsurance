@model EInsurance.Models.DTOs.LoginRequestDto

@{
    ViewData["Title"] = "Login";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">

            <div class="card-header bg-primary text-white text-center">
                <h4>Login</h4>
            </div>

            <div class="card-body">

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-controller="AuthView" asp-action="Login" method="post">

                    <div class="mb-3">
                        <label asp-for="Role" class="form-label">Login As</label>
                        <select asp-for="Role" class="form-select">
                            <option value="">-- Select Role --</option>
                            <option value="Admin">Admin</option>
                            <option value="Employee">Employee</option>
                            <option value="Agent">Agent</option>
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Username</label>
                        <input asp-for="Username" class="form-control"
                               placeholder="Enter username" />
                        <span asp-validation-for="Username" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Password</label>
                        <input asp-for="Password" type="password"
                               class="form-control"
                               placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Login
                    </button>

                </form>

                <hr />
                <div class="text-center">
                    <a asp-controller="AuthView" asp-action="CustomerLogin">
                        Customer? Login here
                    </a>
                    <br />
                    <a asp-controller="AuthView" asp-action="Register">
                        New Customer? Register here
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
