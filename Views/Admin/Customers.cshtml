@model List<EInsurance.Models.DTOs.CustomerListDto>
@{
    ViewData["Title"] = "Manage Customers";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
         @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
         @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2> Customers</h2>
    <a asp-controller="Admin" asp-action="Dashboard"
       class="btn btn-secondary">← Dashboard</a>
</div>

@* Search *@
<div class="card shadow mb-3">
    <div class="card-body py-2">
        <form asp-controller="Admin" asp-action="Customers"
              method="get" class="row g-2">
            <div class="col-md-10">
                <input type="text" name="search"
                       value="@ViewBag.Search"
                       class="form-control"
                       placeholder=" Search by name, email or phone..." />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">Search</button>
            </div>
            <div class="col-md-1">
                <a asp-controller="Admin" asp-action="Customers"
                   class="btn btn-secondary w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

@* Table *@
<div class="card shadow">
    <div class="card-body">
        <table class="table table-hover table-striped align-middle">
            <thead class="table-primary">
                <tr>
                    <th>#</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>DOB</th>
                    <th>Agent</th>
                    <th>Policies</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="9" class="text-center text-muted py-4">
                            No customers found.
                        </td>
                    </tr>
                }
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.CustomerID</td>
                        <td><strong>@c.FullName</strong></td>
                        <td>@c.Email</td>
                        <td>@c.Phone</td>
                        <td>@c.DateOfBirth.ToString("dd/MM/yyyy")</td>
                        <td>@c.AgentName</td>
                        <td>
                            <span class="badge bg-primary">@c.TotalPolicies</span>
                        </td>
                        <td>@c.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-controller="Admin"
                                   asp-action="EditCustomer"
                                   asp-route-id="@c.CustomerID"
                                   class="btn btn-sm btn-warning">✏️</a>

                                <a asp-controller="Policy"
                                   asp-action="CustomerPolicyDetails"
                                   asp-route-id="@c.CustomerID"
                                   class="btn btn-sm btn-info">📋</a>

                                <form asp-controller="Admin"
                                      asp-action="DeleteCustomer"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete @c.FullName?')">
                                    <input type="hidden" name="id" value="@c.CustomerID" />
                                    <button type="submit"
                                            class="btn btn-sm btn-danger">
                                        🗑️
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>