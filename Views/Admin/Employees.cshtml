@model EInsurance.Models.DTOs.PagedResultDto<EInsurance.Models.DTOs.EmployeeListDto>
@{
    ViewData["Title"] = "Manage Employees";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Employees</h2>
    <div class="d-flex gap-2">
        <a asp-controller="Admin" asp-action="RegisterEmployee"
           class="btn btn-warning">+ Register Employee</a>
        <a asp-controller="Admin" asp-action="Dashboard"
           class="btn btn-secondary">← Dashboard</a>
    </div>
</div>

@* Search *@
<div class="card shadow mb-3">
    <div class="card-body py-2">
        <form asp-controller="Admin" asp-action="Employees"
              method="get" class="row g-2">
            <div class="col-md-10">
                <input type="text" name="search"
                       value="@Model.Search" 
                       class="form-control"
                       placeholder="Search employees..." />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-warning w-100">Search</button>
            </div>
            <div class="col-md-1">
                <a asp-controller="Admin" asp-action="Employees"
                   class="btn btn-secondary w-100">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow">
    <div class="card-body">

        <small class="text-muted d-block mb-2">
            Showing <strong>@Model.Items.Count</strong> of
            <strong>@Model.TotalCount</strong> employees
            (Page <strong>@Model.CurrentPage</strong> of <strong>@Model.TotalPages</strong>)
        </small>

        <table class="table table-hover table-striped align-middle">
            <thead class="table-warning">
                <tr>
                    <th>#</th>
                    <th>Username</th>
                    <th>Full Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            No employees found.
                        </td>
                    </tr>
                }
                @foreach (var e in Model.Items)
                {
                    <tr>
                        <td>@e.EmployeeID</td>
                        <td>@e.Username</td>
                        <td><strong>@e.FullName</strong></td>
                        <td>@e.Email</td>
                        <td><span class="badge bg-warning text-dark">@e.Role</span></td>
                        <td>@e.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-controller="Admin"
                                   asp-action="EditEmployee"
                                   asp-route-id="@e.EmployeeID"
                                   class="btn btn-sm btn-warning">✏️</a>
                                <form asp-controller="Admin"
                                      asp-action="DeleteEmployee"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete @e.FullName?')">
                                    <input type="hidden" name="id" value="@e.EmployeeID" />
                                    <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Employee pagination">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link"
                           asp-controller="Admin" asp-action="Employees"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-search="@Model.Search">← Prev</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link"
                               asp-controller="Admin" asp-action="Employees"
                               asp-route-page="@i"
                               asp-route-search="@Model.Search">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link"
                           asp-controller="Admin" asp-action="Employees"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-search="@Model.Search">Next →</a>
                    </li>
                </ul>
            </nav>
        }

    </div>
</div>