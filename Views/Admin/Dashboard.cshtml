@model EInsurance.Models.DTOs.DashboardStatsDto
@{
    ViewData["Title"] = "Admin Dashboard";
}

@* Alerts *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
         @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
         @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2> Admin Dashboard</h2>
    <span class="text-muted">Welcome, @Context.Session.GetString("FullName")</span>
</div>

@* Stats Row *@
<div class="row mb-4">
    <div class="col-md-2 col-sm-6 mb-3">
        <div class="card text-white bg-primary shadow text-center">
            <div class="card-body py-3">
                <h3 class="mb-0">@Model.TotalCustomers</h3>
                <small> Customers</small>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6 mb-3">
        <div class="card text-white bg-success shadow text-center">
            <div class="card-body py-3">
                <h3 class="mb-0">@Model.TotalAgents</h3>
                <small> Agents</small>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6 mb-3">
        <div class="card text-white bg-warning shadow text-center">
            <div class="card-body py-3">
                <h3 class="mb-0">@Model.TotalEmployees</h3>
                <small> Employees</small>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6 mb-3">
        <div class="card text-white bg-danger shadow text-center">
            <div class="card-body py-3">
                <h3 class="mb-0">@Model.TotalPolicies</h3>
                <small> Policies</small>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6 mb-3">
        <div class="card text-white bg-info shadow text-center">
            <div class="card-body py-3">
                <h3 class="mb-0">@Model.TotalPayments</h3>
                <small> Payments</small>
            </div>
        </div>
    </div>
    <div class="col-md-2 col-sm-6 mb-3">
        <div class="card text-white bg-dark shadow text-center">
            <div class="card-body py-3">
                <h6 class="mb-0">₹@Model.TotalRevenue.ToString("N0")</h6>
                <small> Revenue</small>
            </div>
        </div>
    </div>
</div>

@* Management Cards *@
<div class="row">

    @* Customers Card *@
    <div class="col-md-4 mb-4">
        <div class="card shadow h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"> Manage Customers</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">View, search, edit or delete customers.</p>
                <ul class="list-unstyled">
                    <li> View all customers</li>
                    <li> Search by name/email</li>
                    <li> Edit customer details</li>
                    <li> Delete customers</li>
                    <li> View customer policies</li>
                </ul>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-controller="Admin" asp-action="Customers"
                       class="btn btn-primary w-100">
                    View Customers
                </a>
                <a asp-controller="Policy" asp-action="CustomerPolicies"
                       class="btn btn-outline-primary w-100">
                    View Policies
                </a>
            </div>
        </div>
    </div>

    @* Agents Card *@
    <div class="col-md-4 mb-4">
        <div class="card shadow h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0"> Manage Agents</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Register, view, edit or delete agents.</p>
                <ul class="list-unstyled">
                    <li> Register new agent</li>
                    <li> View all agents</li>
                    <li> Search agents</li>
                    <li> Edit agent details</li>
                    <li> Delete agents</li>
                </ul>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-controller="Admin" asp-action="Agents"
                       class="btn btn-success w-100">
                    View Agents
                </a>
                <a asp-controller="Admin" asp-action="RegisterAgent"
                       class="btn btn-outline-success w-100">
                    + New Agent
                </a>
            </div>
        </div>
    </div>

    @* Employees Card *@
    <div class="col-md-4 mb-4">
        <div class="card shadow h-100">
            <div class="card-header bg-warning text-white">
                <h5 class="mb-0"> Manage Employees</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Register, view, edit or delete employees.</p>
                <ul class="list-unstyled">
                    <li> Register new employee</li>
                    <li> View all employees</li>
                    <li> Search employees</li>
                    <li> Edit employee details</li>
                    <li> Delete employees</li>
                </ul>
            </div>
            <div class="card-footer d-flex gap-2">
                <a asp-controller="Admin" asp-action="Employees"
                       class="btn btn-warning w-100">
                    View Employees
                </a>
                <a asp-controller="Admin" asp-action="RegisterEmployee"
                       class="btn btn-outline-warning w-100">
                    + New Employee
                </a>
            </div>
        </div>
    </div>

</div>
