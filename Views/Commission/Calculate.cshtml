@{
    ViewData["Title"] = "Calculate Commission";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
         @TempData["Success"]
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2> Commission Calculator</h2>
    <a asp-controller="Commission"
       asp-action="Index"
       class="btn btn-secondary">← Back to Overview</a>
</div>

<div class="row">

    @* ── Input Form ── *@
    <div class="col-md-4">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Select Agent</h5>
            </div>
            <div class="card-body">
                <form asp-controller="Commission"
                      asp-action="Calculate"
                      method="get">

                    <div class="mb-3">
                        <label class="form-label">Insurance Agent</label>
                        <select name="agentId"
                                class="form-select"
                                asp-items="ViewBag.Agents">
                            <option value="0">-- Select Agent --</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            Commission Rate (%)
                        </label>
                        <input type="number"
                               name="commissionRate"
                               class="form-control"
                               value="@ViewBag.CommissionRate"
                               min="1" max="50"
                               step="0.5" />
                        <small class="text-muted">
                            Typical range: 5% - 20%
                        </small>
                    </div>

                    <button type="submit"
                            class="btn btn-primary w-100">
                         Calculate
                    </button>

                </form>
            </div>
        </div>

        @* Commission Rate Guide *@
        <div class="card shadow mt-3">
            <div class="card-header bg-info text-white">
                <h6 class="mb-0"> Commission Rate Guide</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-info">
                        <tr>
                            <th>Performance</th>
                            <th>Rate</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Standard</td>
                            <td>5% - 8%</td>
                        </tr>
                        <tr class="table-light">
                            <td>Good</td>
                            <td>8% - 12%</td>
                        </tr>
                        <tr>
                            <td>Excellent</td>
                            <td>12% - 20%</td>
                        </tr>
                        <tr class="table-light">
                            <td>Top Performer</td>
                            <td>20%+</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Results ── *@
    <div class="col-md-8">

        @if (ViewBag.Detail != null)
        {
            var detail = (EInsurance.Models.DTOs.AgentCommissionDetailDto)
                          ViewBag.Detail;

            @* Agent Summary Cards *@
            <div class="row mb-3">
                <div class="col-md-3 mb-2">
                    <div class="card text-white bg-primary
                        shadow text-center">
                        <div class="card-body py-2">
                            <h4>@detail.TotalPoliciesSold</h4>
                            <small>Policies Sold</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-2">
                    <div class="card text-white bg-info
                        shadow text-center">
                        <div class="card-body py-2">
                            <h6>₹@detail.TotalPremiumGenerated.ToString("N0")</h6>
                            <small>Premium Generated</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-2">
                    <div class="card text-white bg-warning
                        shadow text-center">
                        <div class="card-body py-2">
                            <h6>@detail.CommissionRate %</h6>
                            <small>Commission Rate</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-2">
                    <div class="card text-white bg-success
                        shadow text-center">
                        <div class="card-body py-2">
                            <h6>₹@detail.TotalCommissionEarned.ToString("N0")</h6>
                            <small>Total Commission</small>
                        </div>
                    </div>
                </div>
            </div>

            @* Agent Info *@
            <div class="card shadow mb-3">
                <div class="card-header bg-dark text-white">
                    <h6 class="mb-0">
                        👤 @detail.AgentName — Commission Details
                    </h6>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <tr class="table-light">
                            <td width="40%"><strong>Agent</strong></td>
                            <td>@detail.AgentName</td>
                        </tr>
                        <tr>
                            <td><strong>Email</strong></td>
                            <td>@detail.Email</td>
                        </tr>
                        <tr class="table-light">
                            <td><strong>Commission Rate</strong></td>
                            <td>@detail.CommissionRate %</td>
                        </tr>
                        <tr>
                            <td><strong>Policies Sold</strong></td>
                            <td>@detail.TotalPoliciesSold</td>
                        </tr>
                        <tr class="table-light">
                            <td><strong>Total Premium</strong></td>
                            <td>₹@detail.TotalPremiumGenerated.ToString("N2")</td>
                        </tr>
                        <tr class="table-success">
                            <td><strong>Total Commission</strong></td>
                            <td class="fw-bold text-success">
                                ₹@detail.TotalCommissionEarned.ToString("N2")
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            @* Policy Breakdown *@
            @if (detail.PolicyCommissions.Any())
            {
                <div class="card shadow mb-3">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0">
                            📋 Policy Breakdown
                        </h6>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm
                            table-striped mb-0">
                            <thead class="table-success">
                                <tr>
                                    <th>Policy #</th>
                                    <th>Customer</th>
                                    <th>Scheme</th>
                                    <th>Premium</th>
                                    <th>Commission (@detail.CommissionRate%)</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in detail.PolicyCommissions)
                                {
                                    <tr>
                                        <td>#@p.PolicyID</td>
                                        <td>@p.CustomerName</td>
                                        <td>
                                            <small>
                                                @p.PlanName →
                                                @p.SchemeName
                                            </small>
                                        </td>
                                        <td>₹@p.Premium.ToString("N2")</td>
                                        <td class="text-success fw-bold">
                                            ₹@p.CommissionAmount.ToString("N2")
                                        </td>
                                        <td>
                                            @p.DateIssued.ToString("dd/MM/yyyy")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-dark">
                                <tr>
                                    <td colspan="3">
                                        <strong>Total</strong>
                                    </td>
                                    <td>
                                        <strong>
                                            ₹@detail.TotalPremiumGenerated
                                            .ToString("N2")
                                        </strong>
                                    </td>
                                    <td class="text-success">
                                        <strong>
                                            ₹@detail.TotalCommissionEarned
                                            .ToString("N2")
                                        </strong>
                                    </td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                @* Save Button *@
                <form asp-controller="Commission"
                      asp-action="Save"
                      method="post">
                    <input type="hidden" name="agentId"
                           value="@detail.AgentID" />
                    <input type="hidden" name="commissionRate"
                           value="@detail.CommissionRate" />
                    <button type="submit"
                            class="btn btn-success w-100"
                            onclick="return confirm(
                        'Save commission for @detail.AgentName?')">
                         Save Commission to Database
                    </button>
                </form>
            }
            else
            {
                <div class="alert alert-warning">
                    This agent has no policies sold yet.
                </div>
            }
        }
        else
        {
            @* Placeholder *@
            <div class="card shadow h-100 border-0 bg-light">
                <div class="card-body d-flex flex-column
                    justify-content-center
                    align-items-center text-center"
                     style="min-height:400px">
                    <h1 class="display-1">💰</h1>
                    <h4 class="text-muted">
                        Select an agent to calculate commission
                    </h4>
                    <p class="text-muted">
                        Choose an agent and set commission
                        rate from the left panel.
                    </p>
                </div>
            </div>
        }
    </div>
</div>